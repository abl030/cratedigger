# Coverage.py config. Used by both:
#   - `coverage run` against the test suite (scripts/run_tests.sh + scripts/coverage_report.sh)
#   - production-instrumented systemd units when services.cratedigger.coverage.enable = true
#     (see nix/module.nix; sets COVERAGE_PROCESS_START to point at this file)
#
# Parallel mode is mandatory: cratedigger spawns subprocesses (import_one.py via
# the beets harness, beet itself isn't ours), the importer + preview workers +
# web run as separate units, and the timer fires every 5 min in a fresh PID.
# Each writes a .coverage.<host>.<pid>.<random> data file; `coverage combine`
# merges them later.

[run]
parallel = True
branch = True
# Long-running services (web, importer, preview worker) only write coverage
# data on graceful exit. systemd sends SIGTERM on stop/restart; this hook
# turns SIGTERM into a normal flush so we don't lose every collection cycle.
# The oneshot timer doesn't need this — atexit already covers it.
sigterm = True
# Production systemd units run with WorkingDirectory=stateDir while the Python
# source lives in the Nix store. Use include globs instead of source=. so
# coverage tracks the packaged source rather than the mutable state directory.
# The local repo glob keeps test-suite coverage comparable.
#
# The store-path NAME is owned by the downstream nixosconfig wrapper, which
# renames the flake input (currently `cratedigger-src-group-permissions`).
# Anchor on the bare substring `cratedigger` — anything tighter has already
# broken collection twice (see tests/test_coverage_config.py, which pins the
# real deployed shape). `/nix/store/*-source/*` covers the unrenamed
# flake-input convention.
#
# Don't track the test suite itself — that conflates "test runs" with "real code
# paths." The whole point of the prod-vs-test diff is to find code only tests
# exercise.
include =
    */cratedigger/*
    /nix/store/*-source/*
    /nix/store/*cratedigger*/*
omit =
    tests/*
    */tests/*
    */test_*.py
    */__pycache__/*
    */site-packages/*
    build/*

[report]
# Display knobs only — don't affect data collection.
skip_empty = True
skip_covered = False
show_missing = True
precision = 1
exclude_also =
    # Don't pretend `if TYPE_CHECKING:` branches are dead code; pyright resolves
    # them at static analysis time and they never execute.
    if TYPE_CHECKING:
    if typing\.TYPE_CHECKING:
    raise NotImplementedError
    @overload
    @abstractmethod

[html]
directory = build/coverage-html

[xml]
output = build/coverage.xml

[paths]
# Coverage records absolute paths in the data file. When prod runs from the Nix
# store (/nix/store/<hash>-source/...) and dev runs from the repo, those paths
# differ — this section tells `coverage combine` they refer to the same source.
# Without it, the prod-vs-test diff would treat every file as two separate
# files.
#
# coverage 7.x rejects patterns ending in a bare wildcard, so each entry
# anchors on a concrete suffix — which means the deployed store-path name
# (owned by the nixosconfig wrapper, which renames the flake input) must be
# spelled out exactly here. If the wrapper renames the derivation, this entry
# AND tests/test_coverage_config.py::DEPLOYED_SRC must follow; the harvest
# guard in scripts/coverage_report.sh (combined file with 0 measured files
# fails loudly) is the runtime backstop. `/nix/store/*-source` covers the
# unrenamed `src = ./.;` convention. The first line — `.` — is the canonical
# prefix; everything else gets rewritten to it.
source =
    .
    /nix/store/*-source
    /nix/store/*-cratedigger-src-group-permissions
    /home/*/cratedigger
