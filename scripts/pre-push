#!/usr/bin/env bash
# Git pre-push hook: validate the exact commit behind every ref before
# anything leaves the machine (tier-2 plan U9, R9 — tags are verifiably
# green without CI; cratedigger's CI is GitGuardian-only by design).
#
# Install once per clone: git config core.hooksPath scripts
#
# Cost: a runtime-source change (lib/, web/, scripts/, harness/,
# migrations/, the two root .py files) rebuilds the package + moduleVm —
# ~1 min with KVM. Docs/tests-only pushes reuse the cached VM: the flake
# filters src to the runtime fileset and the version is content-addressed
# to it, so the derivation only changes when runtime content does.
#
# Each distinct pushed commit is checked once from an isolated detached
# worktree, regardless of the caller's checkout or whether the ref is a
# branch, lightweight tag, or annotated tag.
#
# Deliberate escape hatch: `git push --no-verify`.
set -euo pipefail

# A relative core.hooksPath is resolved from the active worktree root for
# pre-push, so linked worktrees invoke their own tracked version of this
# script. Repository operations use that active worktree while expensive
# gates run in temporary detached worktrees.
REPO_ROOT="$(git rev-parse --show-toplevel)"

declare -a TARGET_COMMITS=()
declare -A TARGET_REFS=()
declare -a VALIDATION_TREES=()
VALIDATION_ROOT=""

collect_push_targets() {
  local local_ref local_oid remote_ref _remote_oid commit ref_description

  while read -r local_ref local_oid remote_ref _remote_oid; do
    [[ -n "${local_ref:-}" ]] || continue

    # Git represents a deletion with an all-zero local object ID. There is
    # no new tree to validate in that case.
    if [[ "$local_oid" =~ ^0+$ ]]; then
      echo "pre-push: skipping deletion of $remote_ref" >&2
      continue
    fi

    # ^{commit} peels branch tips, lightweight tags, and annotated tags,
    # while rejecting blobs, trees, and corrupt/missing local objects.
    if ! commit=$(git -C "$REPO_ROOT" rev-parse --verify "${local_oid}^{commit}" 2>/dev/null); then
      echo "pre-push: ERROR: $local_ref ($local_oid) cannot be peeled to a commit" >&2
      return 1
    fi

    ref_description="$local_ref -> $remote_ref"
    if [[ -v "TARGET_REFS[$commit]" ]]; then
      TARGET_REFS["$commit"]+=", $ref_description"
    else
      TARGET_COMMITS+=("$commit")
      TARGET_REFS["$commit"]="$ref_description"
    fi
  done
}

cleanup_validation_trees() {
  local index tree

  # Remove in reverse creation order. A signal can arrive during
  # `git worktree add`, so also remove the directory if Git did not finish
  # registering it.
  for ((index=${#VALIDATION_TREES[@]} - 1; index >= 0; index--)); do
    tree=${VALIDATION_TREES[$index]}
    git -C "$REPO_ROOT" worktree remove --force "$tree" >/dev/null 2>&1 || rm -rf "$tree"
  done
  if [[ -n "$VALIDATION_ROOT" ]]; then
    rm -rf "$VALIDATION_ROOT"
  fi
}

cleanup_on_exit() {
  local status=$?
  trap - EXIT
  cleanup_validation_trees
  exit "$status"
}

run_gates() {
  local validation_tree=$1
  local commit=$2

  # Randomized generated-test burst (issue #548) — fresh entropy on every
  # push, so exploration of the decision/event state spaces accumulates
  # over time. Modules are discovered by pattern (test_*_generated.py); a
  # hand-maintained list would drift (issue #520 lesson). Modules run in
  # PARALLEL, one process each: the burst is CPU-bound and single-threaded
  # per module, so wall-clock is the slowest module, not the sum. The
  # detached worktree reuses the caller repository's multi-process-safe
  # .hypothesis/ database. Runs BEFORE the flake check: fuzz fails faster
  # than a VM boot.
  # A failed module prints its full output (shrunk world + a
  # @reproduce_failure blob) — promote it per docs/generated-testing.md.
  echo "pre-push: $commit: generated-test fuzz burst (push profile, sharded)..." >&2
  # The single-quoted command is intentionally expanded by the inner shell.
  # shellcheck disable=SC2016
  (cd "$validation_tree" && \
    HYPOTHESIS_STORAGE_DIRECTORY="$REPO_ROOT/.hypothesis" nix-shell --run '
    set -euo pipefail
    logdir=$(mktemp -d)
    trap "rm -rf $logdir" EXIT
    pids=(); mods=()
    for f in tests/test_*_generated.py; do
      mod=${f%.py}; mod=${mod//\//.}
      CRATEDIGGER_HYPOTHESIS_PROFILE=push python3 -m unittest "$mod" \
        > "$logdir/$mod.log" 2>&1 &
      pids+=($!); mods+=("$mod")
    done
    fail=0
    for i in "${!pids[@]}"; do
      if wait "${pids[$i]}"; then
        echo "  ${mods[$i]}: OK" >&2
      else
        echo "  ${mods[$i]}: FAILED" >&2
        cat "$logdir/${mods[$i]}.log" >&2
        fail=1
      fi
    done
    exit "$fail"
  ')
  echo "pre-push: $commit: fuzz burst OK" >&2

  echo "pre-push: $commit: nix flake check (moduleVm + eval guards + CLI bundle)..." >&2
  (cd "$validation_tree" && nix flake check)
  echo "pre-push: $commit: flake check OK" >&2
}

main() {
  local commit validation_tree

  collect_push_targets
  if ((${#TARGET_COMMITS[@]} == 0)); then
    echo "pre-push: no non-deletion refs to validate" >&2
    return 0
  fi

  VALIDATION_ROOT=$(mktemp -d "${TMPDIR:-/tmp}/cratedigger-pre-push.XXXXXX")
  trap cleanup_on_exit EXIT
  trap 'exit 129' HUP
  trap 'exit 130' INT
  trap 'exit 143' TERM

  for commit in "${TARGET_COMMITS[@]}"; do
    validation_tree="$VALIDATION_ROOT/$commit"
    VALIDATION_TREES+=("$validation_tree")
    echo "pre-push: gating commit $commit for refs: ${TARGET_REFS[$commit]}" >&2
    git -C "$REPO_ROOT" worktree add --detach --quiet "$validation_tree" "$commit"
    run_gates "$validation_tree" "$commit"
    git -C "$REPO_ROOT" worktree remove --force "$validation_tree"
    unset 'VALIDATION_TREES[-1]'
  done
}

main "$@"
